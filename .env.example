# Variables de entorno para APPO
# Copia este archivo como .env y completa los valores

# Django Configuration
SECRET_KEY=cambia-esto-por-una-clave-secreta-segura-de-50-caracteres
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Database Configuration
# Dejar vacío para usar SQLite en desarrollo
# POSTGRES_DB=appo_db
# POSTGRES_USER=appo_user
# POSTGRES_PASSWORD=tu-password-seguro
# DATABASE_URL=postgresql://appo_user:tu-password@localhost:5432/appo_db

# Redis (opcional en desarrollo)
# REDIS_URL=redis://localhost:6379/0

# Email Configuration
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=tu-email@gmail.com
EMAIL_HOST_PASSWORD=tu-app-password
DEFAULT_FROM_EMAIL=APPO <noreply@appo.com.co>

# Social Auth (opcional)
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Google Maps API Key
GOOGLE_MAPS_API_KEY=tu-api-key-de-google-maps

# Twilio / WhatsApp (opcional)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_NUMBER=
# TWILIO_WHATSAPP_ENABLED=FALSE

# Meta WhatsApp (producción) — Obligatorio si META_WHATSAPP_ENABLED=True
# META_WHATSAPP_VERIFY_TOKEN=token-seguro-aleatorio
# META_WHATSAPP_WEBHOOK_SECRET=secret-seguro-aleatorio
# META_WHATSAPP_ACCESS_TOKEN=

# Security (producción)
# CSRF_TRUSTED_ORIGINS=https://appo.com.co
# SECURE_SSL_REDIRECT=True

# Celery (opcional)
# CELERY_BROKER_URL=redis://localhost:6379/2
